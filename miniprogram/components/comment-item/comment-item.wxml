<view class="comment-item">
  <view class="comment-main flex">
    <image class="comment-avatar" src="{{avatarUrl}}" mode="aspectFill" bindtap="onAuthorTap" />
    <view class="comment-body flex-1 ml-md">
      <view class="flex items-center justify-between">
        <text class="comment-author" bindtap="onAuthorTap">{{comment.authorName}}</text>
        <text class="comment-time">{{timeText}}</text>
      </view>
      <view class="comment-content mt-sm">
        <text>{{comment.content}}</text>
      </view>
      <view class="comment-actions mt-sm">
        <text class="reply-btn" bindtap="onReply">回复</text>
      </view>

      <!-- Nested Replies -->
      <view wx:if="{{replies.length}}" class="replies-list mt-md">
        <view
          wx:for="{{replies}}"
          wx:key="id"
          class="reply-item flex"
          data-reply="{{item}}"
        >
          <image class="reply-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view class="flex-1 ml-sm">
            <view class="flex items-center justify-between">
              <text class="reply-author">{{item.authorName}}</text>
              <text class="comment-time">{{item.timeText}}</text>
            </view>
            <view class="mt-sm">
              <text class="reply-text">{{item.content}}</text>
            </view>
            <text class="reply-btn mt-sm" catchtap="onReplyToReply" data-reply="{{item}}">回复</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
