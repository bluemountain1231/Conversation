.page-user-profile {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 48rpx;
}

.profile-header {
  position: relative;
  padding-bottom: 40rpx;
  animation: fadeIn 0.4s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 260rpx;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 50%, #7C3AED 100%);
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 80rpx;
  background: linear-gradient(to top, rgba(255,255,255,0.1), transparent);
}

.profile-content {
  position: relative;
  display: flex; flex-direction: column; align-items: center;
  padding-top: 100rpx;
}

.avatar-wrap {
  margin-bottom: 14rpx;
  animation: scalePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

@keyframes scalePop {
  0% { transform: scale(0.7); opacity: 0; }
  60% { transform: scale(1.05); }
  100% { transform: scale(1); opacity: 1; }
}

.profile-avatar {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: #F3F4F6;
  border: 6rpx solid #FFF;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
}

.profile-avatar.avatar-placeholder {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; font-weight: 700;
  border: 6rpx solid #FFF;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
}

.username { color: #111827; font-size: 36rpx; margin-bottom: 6rpx; }

.bio {
  font-size: 24rpx;
  text-align: center;
  padding: 0 48rpx;
  line-height: 1.55;
  color: #6B7280;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin: 0 32rpx;
  padding: 28rpx;
  background: #FFF;
  border-radius: 16rpx;
  position: relative; z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.4s ease 0.2s both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.stat-item {
  display: flex; flex-direction: column; align-items: center; flex: 1;
  transition: transform 0.2s ease;
}

.stat-item:active { transform: scale(0.95); }

.stat-item .stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.stat-item .stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 2rpx;
}

.stat-divider { width: 1rpx; height: 44rpx; background: #E5E7EB; }

.follow-btn-wrap { padding: 24rpx 32rpx 0; }

.follow-btn-wrap .btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.btn-follow-outline {
  background: transparent;
  color: #9CA3AF;
  border: 2rpx solid #E5E7EB;
}

.page-user-profile .divider {
  margin: 0;
  height: 12rpx;
  background: #F7F8FA;
}

.posts-section { background: #FFF; }

.section-header { margin-bottom: 0; padding: 24rpx 32rpx 12rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #111827; }
