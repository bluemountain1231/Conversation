/* ============================================================
   兴趣圈子 Design System — Material Design 3 Blue Theme
   Color Palette:
     primary: #0058bc
     primary-container: #0070eb
     background/surface: #f9f9fe
     surface-container: #ededf2
     surface-container-low: #f3f3f8
     surface-container-lowest: #ffffff
     surface-container-high: #e8e8ed
     on-surface: #1a1c1f
     on-surface-variant: #414755
     outline: #717786
     outline-variant: #c1c6d7
     secondary-container: #e0dfe4
     on-secondary-container: #626267
     error: #ba1a1a
   ============================================================ */

page {
  background: #f9f9fe;
  color: #1a1c1f;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

view, text, image, navigator, scroll-view, swiper, button, input, textarea, form {
  box-sizing: border-box; margin: 0; padding: 0;
}
button { margin: 0; padding: 0; background: none; border: none; line-height: inherit; font-size: inherit; color: inherit; }
button::after { border: none; }
image { display: block; }

/* ── Layout ───────────────────────────────────────────────── */
.container { padding: 0 32rpx; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; min-width: 0; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }

/* ── Spacing ──────────────────────────────────────────────── */
.mt-xs { margin-top: 4rpx; }
.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mt-xl { margin-top: 32rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.mb-lg { margin-bottom: 24rpx; }
.mb-xl { margin-bottom: 32rpx; }
.ml-sm { margin-left: 8rpx; }
.ml-md { margin-left: 16rpx; }
.mr-sm { margin-right: 8rpx; }
.mr-md { margin-right: 16rpx; }
.p-md { padding: 16rpx; }
.p-lg { padding: 24rpx; }
.p-xl { padding: 32rpx; }

/* ── Typography ───────────────────────────────────────────── */
.text-primary { color: #0058bc; }
.text-danger { color: #ba1a1a; }
.text-success { color: #10B981; }
.text-secondary { color: #414755; }
.text-tertiary { color: #717786; }
.text-light { color: #717786; }
.text-dark { color: #1a1c1f; }
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }
.text-bold { font-weight: 600; }
.text-medium { font-weight: 500; }
.text-center { text-align: center; }
.text-right { text-align: right; }

.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.ellipsis-3 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }

/* ── Card ─────────────────────────────────────────────────── */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(26, 28, 31, 0.04);
}

/* ── Shadows ──────────────────────────────────────────────── */
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(26, 28, 31, 0.04); }
.shadow-md { box-shadow: 0 8rpx 24rpx rgba(26, 28, 31, 0.06); }
.shadow-lg { box-shadow: 0 12rpx 40rpx rgba(26, 28, 31, 0.08); }

/* ── Avatar ────────────────────────────────────────────────── */
.avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #f3f3f8; overflow: hidden; flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(26, 28, 31, 0.06);
}
.avatar-sm {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #f3f3f8; overflow: hidden; flex-shrink: 0;
}
.avatar-lg {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: #f3f3f8; overflow: hidden; flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(26, 28, 31, 0.08);
}
.avatar-placeholder {
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #0070eb 0%, #0058bc 100%);
  color: #fff; font-weight: 600; font-size: 28rpx;
}

/* ── Buttons ──────────────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  height: 72rpx; border-radius: 36rpx;
  font-size: 28rpx; font-weight: 500; padding: 0 36rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative; overflow: hidden;
}
.btn:active { transform: scale(0.96); opacity: 0.85; }
.btn-primary {
  background: linear-gradient(135deg, #0058bc 0%, #0070eb 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 88, 188, 0.25);
}
.btn-primary:active { box-shadow: 0 4rpx 12rpx rgba(0, 88, 188, 0.15); }
.btn-outline {
  background: transparent; color: #0058bc;
  border: 2rpx solid #0058bc;
}
.btn-tint { background: rgba(0, 88, 188, 0.08); color: #0058bc; border: none; }
.btn-danger { background: linear-gradient(135deg, #F87171 0%, #ba1a1a 100%); color: #fff; box-shadow: 0 4rpx 16rpx rgba(186, 26, 26, 0.25); }
.btn-gray { background: #e8e8ed; color: #414755; }
.btn-sm { height: 56rpx; border-radius: 28rpx; font-size: 24rpx; padding: 0 24rpx; }
.btn-pill { border-radius: 36rpx; }
.btn-block { width: 100%; }

/* ── Input ─────────────────────────────────────────────────── */
.input-wrap {
  background: #f3f3f8; border-radius: 24rpx;
  padding: 18rpx 20rpx; margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.input-wrap.focus { border-color: #0058bc; background: #fff; box-shadow: 0 0 0 4rpx rgba(0, 88, 188, 0.08); }
.input-wrap input, .input-wrap textarea { width: 100%; font-size: 28rpx; color: #1a1c1f; }
.input-label { font-size: 24rpx; color: #414755; font-weight: 500; margin-bottom: 10rpx; padding-left: 4rpx; }

/* ── Divider ───────────────────────────────────────────────── */
.divider { height: 1rpx; background: #c1c6d7; }

/* ── Tag ───────────────────────────────────────────────────── */
.tag {
  display: inline-flex; align-items: center;
  height: 44rpx; padding: 0 20rpx; border-radius: 22rpx;
  font-size: 22rpx; font-weight: 500;
  background: rgba(0, 88, 188, 0.06); color: #0058bc;
  transition: all 0.2s ease;
}

/* ── Empty ─────────────────────────────────────────────────── */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 120rpx 48rpx;
  animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
}
.empty-icon { font-size: 88rpx; margin-bottom: 24rpx; opacity: 0.2; }
.empty-text { font-size: 28rpx; color: #717786; }

.loading-more {
  text-align: center; padding: 24rpx; color: #717786; font-size: 24rpx;
  animation: fadeIn 0.3s ease both;
}

.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* ── FAB ───────────────────────────────────────────────────── */
.fab {
  position: fixed; right: 32rpx; bottom: 200rpx;
  width: 104rpx; height: 104rpx; border-radius: 52rpx;
  background: linear-gradient(135deg, #0058bc 0%, #0070eb 100%);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 88, 188, 0.35);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.fab text { font-size: 44rpx; font-weight: 300; line-height: 1; }
.fab:active { transform: scale(0.88); box-shadow: 0 4rpx 16rpx rgba(0, 88, 188, 0.2); }

/* ── Section Header ───────────────────────────────────────── */
.section-header { padding: 24rpx 32rpx 12rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1c1f; }

/* ── Animations ───────────────────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scalePop {
  0% { transform: scale(0.8); opacity: 0; }
  60% { transform: scale(1.05); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes scaleIn {
  from { transform: scale(0.92); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes bounceIn {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.08); }
  70% { transform: scale(0.96); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes likePop {
  0% { transform: scale(1); }
  25% { transform: scale(1.35); }
  50% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

@keyframes shimmer {
  0% { background-position: -600rpx 0; }
  100% { background-position: 600rpx 0; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.anim-fade { animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) both; }
.anim-up { animation: fadeInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.anim-scale { animation: scaleIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.anim-pop { animation: scalePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.anim-bounce { animation: bounceIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }

.skeleton {
  background: linear-gradient(90deg, #f3f3f8 25%, #e8e8ed 50%, #f3f3f8 75%);
  background-size: 600rpx 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: 8rpx;
}

.pressable {
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.pressable:active {
  background: #f3f3f8;
  transform: scale(0.98);
}
