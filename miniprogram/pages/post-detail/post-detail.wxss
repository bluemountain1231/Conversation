.detail-page {
  padding: 0;
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFF;
  animation: fadeIn 0.3s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.post-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  border-radius: 0;
  animation: fadeInUp 0.4s ease both;
}

.author-row { position: relative; }

.avatar-placeholder {
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 50%;
}

.author-info { display: flex; flex-direction: column; }

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.3;
}

.post-time { margin-top: 2rpx; line-height: 1.3; color: #D1D5DB; }

.more-btn {
  padding: 12rpx 16rpx;
  transition: transform 0.2s ease;
}

.more-btn:active { transform: scale(0.9); }

.more-icon { font-size: 32rpx; color: #9CA3AF; }

.post-content {
  padding: 28rpx 32rpx;
  border-radius: 0;
  animation: fadeInUp 0.4s ease 0.1s both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.post-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.4;
  letter-spacing: 0.5rpx;
}

.content-body { font-size: 30rpx; color: #374151; line-height: 1.85; }
.rich-content { word-break: break-all; }

.image-gallery {
  display: flex; flex-wrap: wrap; gap: 8rpx;
  animation: fadeIn 0.4s ease 0.2s both;
}

.gallery-item {
  width: calc(33.33% - 6rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  transition: transform 0.2s ease;
}

.gallery-item:active { transform: scale(0.97); }
.gallery-item.single { width: 100%; aspect-ratio: auto; }
.gallery-image { width: 100%; height: 100%; }
.gallery-item.single .gallery-image { max-height: 600rpx; border-radius: 12rpx; }
.circle-tag-wrap { display: flex; }

.action-bar {
  display: flex; align-items: center;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 12rpx solid #F7F8FA;
  background: #FFF; border-radius: 0;
  animation: fadeIn 0.3s ease 0.2s both;
}

.action-item {
  display: flex; align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.action-item:active {
  background: #F3F4F6;
  transform: scale(0.93);
}

.action-item.active { color: #4F46E5; }
.action-item.active .action-icon { color: #4F46E5; }
.action-item.active .action-count { color: #4F46E5; }

.action-icon {
  font-size: 34rpx;
  margin-right: 8rpx;
  color: #9CA3AF;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.action-count {
  font-size: 24rpx;
  color: #9CA3AF;
  transition: color 0.2s ease;
}

.action-share { background: none; border: none; }
.action-share::after { border: none; }
.follow-btn-wrap { margin-left: 16rpx; }

.comments-section { background: #FFF; }

.section-header {
  display: flex; align-items: center;
  padding: 24rpx 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-right: 12rpx;
}

.comment-card { padding: 0 32rpx; }

.bottom-spacer { height: 140rpx; }

.comment-input-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #FFF;
  padding: 14rpx 24rpx;
  border-top: 1rpx solid #F0F0F0;
  z-index: 100;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.reply-hint {
  padding: 10rpx 20rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  animation: fadeIn 0.2s ease both;
}

.cancel-reply { font-weight: 500; color: #4F46E5; }

.input-row { gap: 12rpx; display: flex; align-items: center; }

.comment-input {
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #111827;
  flex: 1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.comment-placeholder { color: #D1D5DB; }

.send-btn {
  height: 72rpx; padding: 0 32rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  display: flex; align-items: center; justify-content: center;
  color: #D1D5DB;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.send-btn-active {
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #FFF;
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.3);
}

.send-btn-active:active {
  transform: scale(0.95);
}

.loading-state { padding: 32rpx; }

.loading-skeleton {
  background: #FFF;
  padding: 32rpx;
  animation: fadeIn 0.3s ease both;
}

.skeleton-header {
  width: 200rpx; height: 48rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 600rpx 100%;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  animation: shimmer 1.5s ease infinite;
}

.skeleton-title {
  width: 80%; height: 32rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 600rpx 100%;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s ease infinite 0.1s;
}

.skeleton-line {
  width: 100%; height: 24rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 600rpx 100%;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  animation: shimmer 1.5s ease infinite 0.2s;
}

.skeleton-line.short { width: 60%; }

@keyframes shimmer {
  0% { background-position: -600rpx 0; }
  100% { background-position: 600rpx 0; }
}
