<view class="login-page">
  <!-- Header -->
  <view class="login-header">
    <text class="header-title">兴趣圈子</text>
    <text class="header-tagline">发现志同道合的人</text>
  </view>

  <!-- Tab Toggle -->
  <view class="tab-bar">
    <view class="tab-item {{mode === 'login' ? 'active' : ''}}" bindtap="switchMode" data-mode="login">
      <text>登录</text>
    </view>
    <view class="tab-item {{mode === 'register' ? 'active' : ''}}" bindtap="switchMode" data-mode="register">
      <text>注册</text>
    </view>
  </view>

  <!-- Form -->
  <view class="login-form">
    <!-- Username (register only) -->
    <view class="input-wrap" wx:if="{{mode === 'register'}}">
      <view class="input-label">用户名</view>
      <input
        class="input-field"
        placeholder="请输入用户名"
        placeholder-class="input-placeholder"
        value="{{username}}"
        bindinput="onUsernameInput"
        maxlength="20"
      />
    </view>

    <!-- Email -->
    <view class="input-wrap">
      <view class="input-label">邮箱</view>
      <input
        class="input-field"
        type="text"
        placeholder="请输入邮箱"
        placeholder-class="input-placeholder"
        value="{{email}}"
        bindinput="onEmailInput"
      />
    </view>

    <!-- Phone (register only, optional) -->
    <view class="input-wrap" wx:if="{{mode === 'register'}}">
      <view class="input-label">手机号 <text class="optional">选填</text></view>
      <input
        class="input-field"
        type="number"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- Password -->
    <view class="input-wrap">
      <view class="input-label">密码</view>
      <input
        class="input-field"
        password
        placeholder="请输入密码"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
        maxlength="32"
      />
    </view>

    <!-- Submit Button -->
    <button class="btn btn-primary btn-block submit-btn" bindtap="onSubmit" disabled="{{loading}}">
      <text wx:if="{{!loading}}">{{mode === 'login' ? '登 录' : '注 册'}}</text>
      <text wx:else>{{mode === 'login' ? '登录中...' : '注册中...'}}</text>
    </button>
  </view>
</view>
