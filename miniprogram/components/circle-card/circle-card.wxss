.circle-card {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(26, 28, 31, 0.04);
  transition: all 0.2s ease;
  animation: ccFadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
}

.circle-card:active {
  transform: scale(0.98);
}

.cc-top {
  display: flex;
  align-items: center;
}

.cc-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f3f3f8;
  flex-shrink: 0;
  margin-right: 24rpx;
  border: 4rpx solid #f3f3f8;
  box-shadow: 0 2rpx 8rpx rgba(26, 28, 31, 0.06);
}

.cc-avatar-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0070eb 0%, #0058bc 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  border: none;
}

.cc-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cc-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1c1f;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cc-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cc-badge {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  background: #e0dfe4;
  color: #626267;
}

.cc-badge-trending {
  background: #e0dfe4;
  color: #626267;
}

.cc-badge-active {
  background: #e0dfe4;
  color: #626267;
}

.cc-badge-new {
  background: #e0dfe4;
  color: #626267;
}

.cc-members {
  font-size: 22rpx;
  color: #717786;
  font-weight: 500;
}

.cc-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.cc-join-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 36rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0058bc 0%, #0070eb 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 88, 188, 0.2);
  transition: all 0.25s ease;
}

.cc-join-btn:active {
  transform: scale(0.94);
}

.cc-joined {
  background: #e8e8ed;
  color: #1a1c1f;
  box-shadow: none;
}

.cc-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #414755;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

@keyframes ccFadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}
