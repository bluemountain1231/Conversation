.page-search { min-height: 100vh; background: #FFF; }

.search-bar {
  background: #FFF;
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  animation: fadeIn 0.3s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.search-input-wrap {
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
  display: flex; align-items: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
}

.search-icon {
  font-size: 28rpx;
  opacity: 0.35;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input { font-size: 28rpx; color: #111827; flex: 1; }
.search-placeholder { color: #D1D5DB; }

.clear-btn {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  color: #9CA3AF; font-size: 24rpx;
  border-radius: 22rpx;
  transition: all 0.2s ease;
}

.clear-btn:active {
  background: #E5E7EB;
  transform: scale(0.9);
}

.tab-bar {
  display: flex; background: #FFF; height: 84rpx;
  border-bottom: 1rpx solid #F0F0F0; padding: 0 24rpx;
}

.tab-item {
  padding: 0 20rpx; font-size: 28rpx; color: #9CA3AF;
  display: flex; align-items: center; position: relative; height: 84rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item.active { color: #111827; font-weight: 700; }

.tab-item.active::after {
  content: ''; position: absolute; bottom: 0;
  left: 50%; transform: translateX(-50%);
  width: 32rpx; height: 6rpx; border-radius: 3rpx;
  background: linear-gradient(90deg, #6366F1, #4F46E5);
  animation: scaleX 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes scaleX {
  from { transform: translateX(-50%) scaleX(0); }
  to { transform: translateX(-50%) scaleX(1); }
}

.initial-state {
  padding: 32rpx;
  animation: fadeInUp 0.4s ease both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.hot-keywords-section { margin-bottom: 40rpx; }

.hot-title {
  font-size: 26rpx; font-weight: 600; color: #6B7280;
  display: block; margin-bottom: 20rpx;
  text-transform: uppercase; letter-spacing: 1rpx;
}

.hot-list { gap: 12rpx; display: flex; flex-wrap: wrap; }

.hot-tag {
  font-size: 24rpx; padding: 12rpx 28rpx; height: auto;
  border-radius: 32rpx; background: #F3F4F6; color: #374151;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-weight: 500;
}

.hot-tag:active {
  background: linear-gradient(135deg, #6366F1, #4F46E5);
  color: #FFF;
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.25);
}

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0;
}

.results-area { }
.result-section { }

.section-header { padding: 24rpx 32rpx 12rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #111827; }
.view-more { font-size: 24rpx; color: #4F46E5; font-weight: 500; }

.user-card {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 32rpx; border-bottom: 1rpx solid #F0F0F0;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.35s ease both;
}

.user-card:active {
  background: #F9FAFB;
  transform: scale(0.99);
}

.user-avatar-wrap .user-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #F3F4F6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.user-avatar-wrap .avatar-placeholder {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(79, 70, 229, 0.2);
}

.user-info { min-width: 0; flex: 1; }
.user-name { font-size: 28rpx; font-weight: 600; color: #111827; display: block; margin-bottom: 4rpx; }
.user-bio { display: block; color: #9CA3AF; }
