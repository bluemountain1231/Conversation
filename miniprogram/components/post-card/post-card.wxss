.post-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 0 20rpx;
  overflow: hidden;
  transition: transform 0.2s ease;
  animation: pcFadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
}

.post-card:active {
  transform: scale(0.98);
}

.pc-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 0;
}

.pc-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ededf2;
  flex-shrink: 0;
  margin-right: 20rpx;
  border: 2rpx solid #f3f3f8;
}

.pc-author-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pc-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pc-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1c1f;
}

.pc-popular-badge {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  background: #e0dfe4;
  color: #626267;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.pc-meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.pc-time {
  font-size: 22rpx;
  color: #414755;
}

.pc-circle-dot {
  font-size: 22rpx;
  color: #c1c6d7;
}

.pc-circle-name {
  font-size: 22rpx;
  color: #414755;
}

.pc-more {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 32rpx;
  color: #414755;
  flex-shrink: 0;
}

.pc-more:active {
  background: #f3f3f8;
}

.pc-content {
  font-size: 28rpx;
  color: #1a1c1f;
  line-height: 1.7;
  padding: 16rpx 28rpx;
  word-break: break-all;
}

.pc-single-img {
  margin: 0 28rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ededf2;
}

.pc-single-img image {
  width: 100%;
  max-height: 600rpx;
  border-radius: 24rpx;
}

.pc-img-grid {
  display: flex;
  gap: 6rpx;
  margin: 0 28rpx;
}

.pc-grid-item {
  flex: 1;
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #ededf2;
}

.pc-cols-2 .pc-grid-item {
  height: 260rpx;
}

.pc-grid-item image {
  width: 100%;
  height: 100%;
}

.pc-grid-more {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4rpx);
}

.pc-actions {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 8rpx;
}

.pc-act {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.pc-act:active {
  background: #f3f3f8;
  transform: scale(0.92);
}

.pc-act-icon {
  font-size: 32rpx;
  color: #414755;
  line-height: 1;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.pc-act-num {
  font-size: 24rpx;
  color: #414755;
  font-weight: 500;
}

.pc-act-liked .pc-act-icon,
.pc-act-liked .pc-act-num {
  color: #0058bc;
}

.pc-act-faved .pc-act-icon {
  color: #0058bc;
}

.pc-spacer {
  flex: 1;
}

.pc-pop {
  animation: pcLikePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes pcFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pcLikePop {
  0% { transform: scale(1); }
  30% { transform: scale(1.5); }
  60% { transform: scale(0.85); }
  100% { transform: scale(1); }
}
