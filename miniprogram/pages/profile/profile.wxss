.page-profile {
  min-height: 100vh;
  background: #f9f9fe;
  padding-bottom: 140rpx;
}

/* Login prompt */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 48rpx;
  background: #f9f9fe;
}

.ill-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.15; }
.ill-title { font-size: 36rpx; font-weight: 700; color: #1a1c1f; margin-bottom: 8rpx; }
.ill-sub { font-size: 26rpx; color: #717786; }

/* Profile header */
.profile-header {
  background: #f9f9fe;
  padding: 16rpx 32rpx 0;
}

.ph-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.ph-avatar-wrap {
  flex-shrink: 0;
}

.ph-avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #f3f3f8;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(26, 28, 31, 0.06);
}

.ph-avatar-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0070eb, #0058bc);
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
}

.ph-info {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

.ph-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1c1f;
  letter-spacing: -1rpx;
}

.ph-handle {
  font-size: 24rpx;
  color: #414755;
  font-weight: 500;
  margin-top: 4rpx;
}

.ph-edit-btn {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: #0070eb;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
  transition: all 0.2s;
}

.ph-edit-btn:active {
  transform: scale(0.95);
}

.ph-bio {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #414755;
  line-height: 1.6;
  max-width: 500rpx;
}

/* Stats */
.ph-stats {
  display: flex;
  gap: 48rpx;
  margin-top: 28rpx;
  padding: 24rpx 32rpx;
  background: #f3f3f8;
  border-radius: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-item:last-child {
  margin-left: auto;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1c1f;
}

.stat-item:last-child .stat-num {
  color: #0058bc;
}

.stat-label {
  font-size: 20rpx;
  color: #414755;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.stat-item:last-child .stat-label {
  color: #0058bc;
}

/* Tabs */
.profile-tabs {
  display: flex;
  background: rgba(249, 249, 254, 0.95);
  -webkit-backdrop-filter: blur(20rpx);
  backdrop-filter: blur(20rpx);
  position: sticky;
  top: 0;
  z-index: 10;
  margin-top: 16rpx;
}

.pt-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 26rpx;
  color: #414755;
  font-weight: 600;
  position: relative;
  transition: all 0.25s ease;
}

.pt-active {
  color: #0058bc;
}

.pt-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #0058bc;
}

/* Post grid */
.post-grid-section {
  background: #f9f9fe;
  min-height: 300rpx;
  padding: 16rpx;
}

/* 2-column grid */
.post-grid-2col {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* Full-width featured card */
.grid-feature-card {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  margin-bottom: 12rpx;
  transition: transform 0.2s ease;
}

.grid-feature-card:active {
  transform: scale(0.98);
}

.gfc-image-wrap {
  width: 100%;
  height: 380rpx;
  position: relative;
  background: #ededf2;
}

.gfc-image {
  width: 100%;
  height: 100%;
}

.gfc-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  height: 36rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background: rgba(224, 223, 228, 0.8);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
  color: #626267;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  letter-spacing: 2rpx;
}

.gfc-info {
  padding: 20rpx 24rpx;
}

.gfc-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1c1f;
  margin-bottom: 6rpx;
}

.gfc-desc {
  display: block;
  font-size: 24rpx;
  color: #414755;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Square grid items */
.grid-square-item {
  width: calc(50% - 6rpx);
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  transition: transform 0.2s ease;
}

.grid-square-item:active {
  transform: scale(0.98);
}

.gsi-image {
  width: 100%;
  height: 280rpx;
}

.gsi-placeholder {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #e8e8ed, #f3f3f8);
}

.gsi-title {
  display: block;
  padding: 16rpx 16rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1c1f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Empty / Loading */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #c1c6d7;
}

.loading-indicator {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #717786;
}

/* Menu */
.profile-menu {
  margin-top: 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-left: 16rpx;
  margin-right: 16rpx;
  overflow: hidden;
}

.pm-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f3f8;
  transition: background 0.2s;
}

.pm-item:last-child {
  border-bottom: none;
}

.pm-item:active {
  background: #f3f3f8;
}

.pm-icon {
  font-size: 36rpx;
  width: 52rpx;
  margin-right: 16rpx;
  text-align: center;
}

.pm-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1c1f;
  font-weight: 500;
}

.pm-arrow {
  font-size: 32rpx;
  color: #c1c6d7;
}
