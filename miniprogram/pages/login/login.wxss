.login-page {
  min-height: 100vh; background: #FFF;
  padding: 0 40rpx 80rpx;
}

.login-header {
  text-align: center;
  padding: 120rpx 0 56rpx;
  animation: fadeInDown 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.header-tagline {
  display: block;
  font-size: 28rpx;
  color: #9CA3AF;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.tab-bar {
  display: flex; margin-bottom: 48rpx;
  border-bottom: 2rpx solid #F0F0F0;
  animation: fadeIn 0.4s ease 0.2s both;
}

.tab-item {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #9CA3AF; position: relative;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 500;
}

.tab-item.active { color: #111827; font-weight: 700; }

.tab-item.active::after {
  content: ''; position: absolute; bottom: -2rpx;
  left: 50%; transform: translateX(-50%);
  width: 56rpx; height: 6rpx; border-radius: 3rpx;
  background: linear-gradient(90deg, #6366F1, #4F46E5);
  animation: scaleX 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes scaleX {
  from { transform: translateX(-50%) scaleX(0); }
  to { transform: translateX(-50%) scaleX(1); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.login-form {
  animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.3s both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.login-form .input-wrap {
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.login-form .input-wrap:last-of-type {
  margin-bottom: 0;
}

.login-form .input-label {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
  margin-bottom: 10rpx;
  padding-left: 0;
}

.optional { font-size: 22rpx; color: #D1D5DB; font-weight: 400; }

.input-field {
  width: 100%;
  font-size: 30rpx;
  color: #111827;
}

.input-placeholder { color: #D1D5DB; }

.submit-btn {
  margin-top: 48rpx;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #0058bc 0%, #0070eb 100%);
  color: #FFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 88, 188, 0.3);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.submit-btn::after { border: none; }

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.25);
}

.submit-btn[disabled] {
  opacity: 0.4;
  box-shadow: none;
}
