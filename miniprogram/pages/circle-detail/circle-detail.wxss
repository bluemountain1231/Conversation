.page-circle-detail {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 48rpx;
}

.circle-header {
  margin: 0;
  padding: 32rpx;
  background: #FFF;
  border-radius: 0;
  animation: fadeIn 0.4s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.header-top { gap: 24rpx; }

.circle-avatar-wrap .circle-avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 24rpx;
  background: #F3F4F6;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.circle-avatar-wrap .avatar-placeholder {
  width: 120rpx; height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #fff; font-size: 48rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.25);
}

.header-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.circle-name {
  display: block;
  font-size: 38rpx;
  color: #111827;
  margin-bottom: 10rpx;
  font-weight: 700;
}

.circle-desc {
  display: -webkit-box;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.55;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.creator-label { display: block; color: #9CA3AF; }

.stats-row { gap: 16rpx; }

.stat-badge {
  display: flex; align-items: baseline; gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(79, 70, 229, 0.04);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.stat-badge:active { transform: scale(0.96); }

.stat-badge .stat-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #4F46E5;
}

.stat-badge .stat-label {
  font-size: 22rpx;
  color: #6B7280;
}

.join-btn-wrap { width: 100%; }

.btn-leave {
  background: transparent;
  color: #EF4444;
  border: 2rpx solid #EF4444;
}

.members-section {
  margin: 12rpx 0 0;
  padding: 24rpx 32rpx;
  background: #FFF;
  border-radius: 0;
  animation: fadeInUp 0.4s ease 0.1s both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section-header { margin-bottom: 16rpx; padding: 0; }
.section-title { font-size: 28rpx; font-weight: 700; color: #111827; }
.member-total { font-size: 22rpx; color: #9CA3AF; }

.members-row { gap: 20rpx; overflow-x: auto; padding-bottom: 8rpx; }

.member-item {
  display: flex; flex-direction: column; align-items: center;
  width: 80rpx; flex-shrink: 0;
  transition: transform 0.2s ease;
}

.member-item:active { transform: scale(0.92); }

.member-item .member-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: #F3F4F6;
  margin-bottom: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.member-item .avatar-placeholder {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 600;
  margin-bottom: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(79, 70, 229, 0.2);
}

.member-name {
  font-size: 20rpx; color: #9CA3AF;
  max-width: 80rpx; text-align: center;
}

.page-circle-detail .divider {
  margin: 0; height: 12rpx; background: #F7F8FA;
}

.posts-section { background: #FFF; }

.posts-section .section-header {
  margin-bottom: 0;
  padding: 24rpx 32rpx 12rpx;
}
